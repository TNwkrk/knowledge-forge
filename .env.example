# Documentation only: keep real secrets in Infisical and inject them at runtime
# with `infisical run -- ...` instead of committing local env files.

# OpenAI API key used for extraction and compilation requests.
OPENAI_API_KEY=

# Local path to the Knowledge Forge working data directory.
KNOWLEDGE_FORGE_DATA_DIR=./data

# Local path to the downstream FlowCommander clone for inspection and publish prep.
FLOWCOMMANDER_REPO=/Users/taylor/development/FlowCommander

# GitHub token used for PR-oriented workflows against GitHub repositories.
GITHUB_TOKEN=
